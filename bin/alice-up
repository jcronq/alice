#!/usr/bin/env bash
# Start Alice's sandbox (daemon + one worker slot) if not already running.
# Idempotent. Readiness = some worker holds the flock on /state/worker/lease.
set -euo pipefail

ALICE_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
cd "$ALICE_ROOT/sandbox"

if ! command -v docker >/dev/null 2>&1; then
    echo "alice-up: docker not found on PATH. Install Docker (or Docker Desktop) and retry." >&2
    exit 1
fi
if ! docker info >/dev/null 2>&1; then
    echo "alice-up: docker daemon isn't running (or your user can't reach it). Start it and retry." >&2
    exit 1
fi

export USER_ID="${USER_ID:-$(id -u)}"
export GROUP_ID="${GROUP_ID:-$(id -g)}"
# Bind the alice repo from wherever this script lives, so the worker's
# /home/alice/alice mount points at *this* checkout — no matter if it's
# ~/alice, ~/dev/alice, or somewhere else entirely.
export ALICE_REPO="${ALICE_REPO:-$ALICE_ROOT}"
# Mind + tools live under <repo>/data/ by default (gitignored as a whole).
# Mind is its own git repo; tools is just a directory of scripts.
# Override either env var to put them elsewhere.
export ALICE_MIND="${ALICE_MIND:-$ALICE_ROOT/data/alice-mind}"
export ALICE_TOOLS="${ALICE_TOOLS:-$ALICE_ROOT/data/alice-tools}"

# Pre-create host directories that compose binds. If we don't, the docker
# daemon creates them as root:root on first run and Alice (uid 1000) can't
# write. Idempotent.
mkdir -p \
    "$ALICE_MIND" \
    "$ALICE_TOOLS" \
    "$HOME/.config/alice" \
    "$HOME/.config/gh" \
    "$HOME/.alice-claude" \
    "$HOME/.local/state/alice" \
    "$HOME/.local/share/signal-cli"

# Is a worker already up and holding the lease?
for name in alice-worker-blue alice-worker-green; do
    state="$(docker inspect -f '{{.State.Status}}' "$name" 2>/dev/null || echo missing)"
    if [ "$state" = "running" ]; then
        if ! docker exec "$name" flock -n /state/worker/lease true 2>/dev/null; then
            exit 0  # already live
        fi
    fi
done

# Build any image whose Dockerfile or build context changed since last
# build. Cached layers stay cached, so a no-op warm start costs ~1-2s of
# "everything cached" output. The previous "build only when no image
# exists" gate skipped rebuilds after a `git pull` that changed a
# Dockerfile, so a stale `:blue` from an earlier install kept being
# reused — the daemon then crash-looped on whatever new dep the new
# Dockerfile expected (issue #1). Building blue here also seeds it on
# very first start. Green is left alone: alice-deploy is the path that
# updates green, and pre-building both slots would double the cost
# without benefit.
docker compose --profile blue build alice-daemon alice-viewer alice-worker-blue >/dev/null

# Bring up the daemon + observability viewer (always-on, host-side UI).
docker compose up -d alice-daemon alice-viewer >/dev/null

# Start whichever slot has a built image (prefer blue).
if docker image inspect alice-worker:blue >/dev/null 2>&1; then
    docker compose --profile blue up -d alice-worker-blue >/dev/null
elif docker image inspect alice-worker:green >/dev/null 2>&1; then
    docker compose --profile green up -d alice-worker-green >/dev/null
fi

# Wait for a worker to acquire the lease.
for _ in $(seq 1 90); do
    for name in alice-worker-blue alice-worker-green; do
        if docker ps --filter "name=^${name}$" --format '{{.Names}}' | grep -q .; then
            if ! docker exec "$name" flock -n /state/worker/lease true 2>/dev/null; then
                exit 0
            fi
        fi
    done
    sleep 0.5
done

echo "alice-up: no worker acquired the lease within 45s" >&2
exit 1
