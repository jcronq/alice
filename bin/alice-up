#!/usr/bin/env bash
# Start Alice's sandbox container if it isn't already running. Idempotent.
set -euo pipefail

cd "$(dirname "$0")/../sandbox"

export USER_ID="${USER_ID:-$(id -u)}"
export GROUP_ID="${GROUP_ID:-$(id -g)}"

state="$(docker inspect -f '{{.State.Status}}' alice 2>/dev/null || echo 'missing')"

case "$state" in
    running) exit 0 ;;
    missing) docker compose up -d ;;
    *)       docker start alice >/dev/null ;;
esac

# Wait until the container is ready (a simple exec succeeds).
for _ in $(seq 1 30); do
    if docker exec alice true 2>/dev/null; then exit 0; fi
    sleep 0.2
done

echo "alice-up: container did not become ready" >&2
exit 1
