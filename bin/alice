#!/usr/bin/env bash
# Run `claude` inside Alice's sandbox. Targets the worker that currently holds
# the message-processing lease, so the call goes to the live bridge in either
# steady state or mid-blue/green.
#
# Usage:
#   alice                          # interactive chat
#   alice "what's on today?"       # one-shot
#   alice -p "summary" --resume ID # any claude CLI flags
set -euo pipefail

"$(dirname "$0")/alice-up"

# Pick the worker holding the lease. If none (transient during handoff), fall
# back to the canonical name.
pick_worker() {
    # "This container's bridge holds the lease" = flock probe fails (someone
    # already holds the exclusive lock on /state/worker/lease).
    local name
    for name in $(docker ps --filter label=alice.role=worker --format '{{.Names}}' 2>/dev/null); do
        if ! docker exec "$name" flock -n /state/worker/lease true 2>/dev/null; then
            printf '%s\n' "$name"
            return 0
        fi
    done
    printf 'alice-worker\n'
}

WORKER="$(pick_worker)"

if [ -t 0 ] && [ -t 1 ]; then
    exec docker exec -u alice -it "$WORKER" claude "$@"
else
    exec docker exec -u alice -i "$WORKER" claude "$@"
fi
