#!/usr/bin/env bash
# alice-init — first-run setup for a fresh Alice install.
#
# Prompts for:
#   1. Where Alice's mind lives (existing repo URL, existing local path,
#      or new local scaffold).
#   2. Optional Signal account + allowlisted senders, to seed
#      ~/.config/alice/alice.env. Skip this step to run CLI-only.
#
# Does NOT:
#   - Register the signal-cli account (interactive `signal-cli link`).
#   - Create a GitHub repo for the mind (user runs `gh repo create` if/when).
#   - Start the container (prints the command).
#
# Usage:
#   alice-init                 # interactive, targets <repo>/data/alice-mind
#   alice-init --target PATH   # scaffold into a different dir
#   alice-init --yes           # accept defaults (skips Signal prompt)

set -euo pipefail

ALICE_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
SCAFFOLD_SRC="$ALICE_ROOT/templates/mind-scaffold"
# Mind + tools live under <repo>/data/ by default — that whole directory
# is gitignored in this (runtime) repo. The mind is itself a separate
# git repo created by the scaffold step below; tools is just a directory.
TARGET="$ALICE_ROOT/data/alice-mind"
TOOLS_DIR="$ALICE_ROOT/data/alice-tools"
NON_INTERACTIVE=0

# ----- prerequisite check -----
missing=()
command -v docker >/dev/null 2>&1 || missing+=(docker)
command -v git    >/dev/null 2>&1 || missing+=(git)
if [ ${#missing[@]} -gt 0 ]; then
    echo "alice-init: missing prerequisites: ${missing[*]}" >&2
    echo "  Install them and retry. (gh is optional; only needed if you push the mind to GitHub.)" >&2
    exit 1
fi

while [ $# -gt 0 ]; do
    case "$1" in
        --target)   TARGET="$2"; shift 2 ;;
        --target=*) TARGET="${1#--target=}"; shift ;;
        --yes|-y)   NON_INTERACTIVE=1; shift ;;
        -h|--help)
            sed -n '3,19p' "$0"
            exit 0
            ;;
        *)
            echo "alice-init: unexpected arg '$1'" >&2
            exit 2
            ;;
    esac
done

ask() {
    # ask PROMPT DEFAULT
    local prompt="$1" default="${2:-}"
    if [ "$NON_INTERACTIVE" -eq 1 ]; then
        printf '%s\n' "$default"
        return
    fi
    local reply
    if [ -n "$default" ]; then
        read -r -p "$prompt [$default]: " reply
    else
        read -r -p "$prompt: " reply
    fi
    printf '%s\n' "${reply:-$default}"
}

confirm() {
    # confirm PROMPT DEFAULT(y|n)
    local prompt="$1" default="${2:-y}"
    if [ "$NON_INTERACTIVE" -eq 1 ]; then
        [ "$default" = "y" ]
        return
    fi
    local reply
    read -r -p "$prompt [$default]: " reply
    reply="${reply:-$default}"
    case "$reply" in y|Y|yes|YES) return 0 ;; *) return 1 ;; esac
}

echo "=== Alice first-run setup ==="
echo

# Ensure <repo>/data/ exists so all three mind-source paths below have a
# stable parent (git clone won't create intermediate parents).
mkdir -p "$(dirname "$TARGET")"

# ----- mind source -----
echo "Where should Alice's mind live?"
echo "  1) git clone an existing repo"
echo "  2) use an existing local directory"
echo "  3) create a fresh one from the default scaffold"
choice=$(ask "Pick 1/2/3" "3")

case "$choice" in
    1)
        url=$(ask "git URL (https or ssh)")
        if [ -z "$url" ]; then
            echo "no URL given, aborting" >&2
            exit 1
        fi
        target=$(ask "clone target path" "$TARGET")
        if [ -e "$target" ]; then
            echo "$target already exists — refusing to clobber" >&2
            exit 1
        fi
        git clone "$url" "$target"
        TARGET="$target"
        ;;
    2)
        path=$(ask "existing mind path" "$TARGET")
        if [ ! -d "$path" ]; then
            echo "$path is not a directory" >&2
            exit 1
        fi
        TARGET="$path"
        if [ ! -d "$TARGET/.git" ]; then
            if confirm "No git repo in $TARGET. git init it?" "y"; then
                ( cd "$TARGET" && git init -q -b master )
            fi
        fi
        ;;
    3|*)
        target=$(ask "scaffold target path" "$TARGET")
        if [ -e "$target" ]; then
            if ! confirm "$target exists. overlay scaffold into it?" "n"; then
                exit 1
            fi
        fi
        mkdir -p "$target"
        # Copy scaffold preserving hidden files (.claude/, .githooks/, etc.)
        cp -a "$SCAFFOLD_SRC"/. "$target"/
        TARGET="$target"
        if [ ! -d "$TARGET/.git" ]; then
            (
                cd "$TARGET"
                git init -q -b master
                git config core.hooksPath .githooks
                git add -A
                git commit -q -m "Initial scaffold from alice-init"
            )
            echo "initialized git repo at $TARGET (no remote set)"
        fi
        ;;
esac

echo "mind: $TARGET"
echo

# ----- alice.env -----
cfg_dir="$HOME/.config/alice"
cfg_file="$cfg_dir/alice.env"
mkdir -p "$cfg_dir"

if [ -f "$cfg_file" ]; then
    echo "$cfg_file already exists; leaving it alone."
else
    signal_account=""
    allowed_senders=""
    echo "=== Transports (stored in $cfg_file) ==="
    echo "Signal is optional. Skip this step if you only want the CLI"
    echo "transport (alice / alice -p '...') — you can wire Signal later."
    echo
    if confirm "Configure Signal now?" "n"; then
        echo "(You'll still need to register the account via 'signal-cli link' afterwards.)"
        signal_account=$(ask "SIGNAL_ACCOUNT (E.164, e.g. +15555550100)")
        allowed_senders=$(ask "ALLOWED_SENDERS (comma-separated, e.g. +15555551212:Alice)")
    fi

    cp "$ALICE_ROOT/config/alice.env.example" "$cfg_file"
    # Use python for safe sed replacement (handles metacharacters).
    python3 - "$cfg_file" "$signal_account" "$allowed_senders" <<'PY'
import sys, pathlib
path, account, senders = sys.argv[1], sys.argv[2], sys.argv[3]
txt = pathlib.Path(path).read_text()
txt = txt.replace("SIGNAL_ACCOUNT=\n", f"SIGNAL_ACCOUNT={account}\n")
txt = txt.replace("ALLOWED_SENDERS=\n", f"ALLOWED_SENDERS={senders}\n")
pathlib.Path(path).write_text(txt)
PY
    chmod 600 "$cfg_file"
    echo "wrote $cfg_file"
fi

# Pre-create host directories that compose binds, so docker doesn't make
# them root-owned on first start. alice-up does this too — running here
# means a user who edits files between init and up sees the right paths.
mkdir -p \
    "$TOOLS_DIR" \
    "$HOME/.config/gh" \
    "$HOME/.alice-claude" \
    "$HOME/.local/state/alice" \
    "$HOME/.local/share/signal-cli"

# Resolve the Signal account from the env file for the next-steps blurb
# (empty when Signal wasn't configured).
SIGNAL_ACCOUNT_VAL=""
if [ -f "$cfg_file" ]; then
    SIGNAL_ACCOUNT_VAL="$(. "$cfg_file" 2>/dev/null && echo "${SIGNAL_ACCOUNT:-}")"
fi

# ----- wrap-up -----
cat <<EOF

=== Next steps ===

1. Add $ALICE_ROOT/bin to your PATH:
      export PATH="$ALICE_ROOT/bin:\$PATH"   # persist in your shell rc

2. Personalize Alice's mind (optional — defaults work):
      editor $TARGET/IDENTITY.md
      editor $TARGET/CLAUDE.md
      editor $TARGET/USER.md

EOF

step=3
# Always nudge toward the long-lived token. We do not direct users to
# 'claude /login' because on macOS that token lives in the system
# Keychain (unreachable from the container), and even on Linux a
# refresh in ~/.claude/.credentials.json doesn't always propagate
# cleanly through the bind mount.
cat <<EOF
$step. Mint a long-lived Claude OAuth token (one-time):
      claude setup-token      # opens a browser; copy the printed token
   Then add it to $cfg_file:
      CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat01-…

EOF
step=$((step + 1))

if [ -n "$SIGNAL_ACCOUNT_VAL" ]; then
    cat <<EOF
$step. Register Signal (once, interactive — the daemon must be up):
      alice-up
      docker exec -it alice-daemon signal-cli -a "$SIGNAL_ACCOUNT_VAL" link -n "Alice"
   Scan the QR code with your phone's Signal app.

EOF
    step=$((step + 1))
fi

cat <<EOF
$step. Bring up the sandbox and talk to her:
      alice-up        # starts the daemon + worker + viewer
      alice           # interactive CLI
      alice -p "ping" # one-shot

EOF

cat <<EOF
Optional: push the mind to a private GitHub repo:
      cd $TARGET
      gh repo create --private --source . --push

EOF
