#!/usr/bin/env bash
# Stop Alice's sandbox. Use --rm to also remove containers (volumes persist
# either way).
set -euo pipefail

cd "$(dirname "$0")/../sandbox"

if [ "${1:-}" = "--rm" ]; then
    docker compose down
else
    # Stop in reverse dependency order so the worker drains first.
    docker stop alice-worker 2>/dev/null || true
    docker stop alice-daemon 2>/dev/null || true
fi
