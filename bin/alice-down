#!/usr/bin/env bash
# Stop Alice's sandbox. Use --rm to also remove containers (volumes persist
# either way).
set -euo pipefail

cd "$(dirname "$0")/../sandbox"

if [ "${1:-}" = "--rm" ]; then
    docker compose --profile blue --profile green down
else
    # Stop worker slots first (drains in-flight claude), then daemon.
    for name in alice-worker-blue alice-worker-green; do
        docker stop "$name" 2>/dev/null || true
    done
    docker stop alice-daemon 2>/dev/null || true
fi
