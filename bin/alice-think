#!/usr/bin/env bash
# alice-think — one wake of Alice's thinking hemisphere.
#
# Thin shim over python -m alice_speaking.think (uses the speaking venv so we
# get the Claude Agent SDK — direct `claude -p` hangs on TTY detection in
# non-interactive contexts per Issue #9026). The Python entry is where config
# overrides, prompt assembly, timeout, and structured event logging live.
#
# Usage:
#   alice-think                  # full wake, reads prompts/thinking-bootstrap.md
#   alice-think --quick          # 30s plumbing smoke test
#   alice-think --echo           # also emit events to stderr
#   alice-think --max-seconds 90 # cap wake at 90s for faster iteration
#
# Singleton enforcement is external — alice-thinker's supervisor wraps each
# invocation in `flock -n /state/worker/thinking.lock`.
set -u

VENV_PY="/opt/alice-speaking-venv/bin/python"
ALICE_SPEAKING_SRC="${ALICE_SPEAKING_SRC:-/home/alice/alice-speaking/src}"

if [ ! -x "$VENV_PY" ]; then
    echo "[alice-think] venv python missing at $VENV_PY" >&2
    exit 1
fi

export PYTHONPATH="$ALICE_SPEAKING_SRC"
export PYTHONUNBUFFERED=1
exec "$VENV_PY" -m alice_speaking.think "$@"
