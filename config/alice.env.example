# Alice runtime configuration.
# Copy to ~/.config/alice/alice.env and fill in.
# DO NOT commit secrets into this template.
#
# `alice-init` will create this file for you with the values you pass.

# SIGNAL_API is set by docker-compose (the worker reaches the daemon at
# http://alice-daemon:8080 on the internal Docker network). Only set it here
# if you're running the bridge outside the normal compose layout.

# signal-cli account — the E.164 phone number Alice sends from.
# Register with: signal-cli -a +15555550100 link -n "Alice" (or `register`).
SIGNAL_ACCOUNT=

# Comma-separated allowlist of senders who can message Alice.
# Format: "+15555550100:DisplayName,+15555550101:Other"
ALLOWED_SENDERS=

# Claude Code working directory inside the container.
# Should always be /home/alice/alice-mind in the default setup.
WORK_DIR=/home/alice/alice-mind

# Max seconds a single claude invocation is allowed to run.
# Must be strictly less than FLOCK_TIMEOUT so the lock always releases before
# the next queued message times out.
CLAUDE_TIMEOUT=240

# Max seconds a queued message will wait for the per-sender lock.
FLOCK_TIMEOUT=300

# Tools exposed to claude inside signal-bridge invocations.
# Drop Bash from this list to reduce prompt-injection blast radius.
CLAUDE_ALLOWED_TOOLS=Bash,Read,Write,Edit,Glob,Grep

# --- Discord (optional) ----------------------------------------------------
# Alice can also talk over Discord (DMs and mentions in guilds she's been
# invited to). Leave DISCORD_BOT_TOKEN empty to disable; the daemon skips
# Discord construction entirely and existing Signal-only deploys are
# unaffected.
#
# To enable:
#   1. Create a bot at https://discord.com/developers/applications, copy
#      its token into DISCORD_BOT_TOKEN below.
#   2. Enable the "Message Content" privileged intent on the bot's app page.
#   3. Invite the bot to your guild with the `bot` scope and at minimum
#      Send Messages + Read Message History permissions.
#   4. Add a Discord channel entry to each principal you want speaking on
#      Discord (in alice-mind/config/principals.yaml) — DMs match by user
#      id, guild messages match by channel id.
DISCORD_BOT_TOKEN=
