# Alice runtime configuration.
# Copy to ~/.config/alice/alice.env and fill in.
# DO NOT commit secrets into this template.
#
# `alice-init` will create this file for you with the values you pass.

# --- Claude auth -----------------------------------------------------------
# Pick ONE of the modes below. install.sh will prompt and fill in the
# right one for you; you only need to edit by hand if you're swapping
# modes after install.
#
# For per-hemisphere backend selection (e.g. thinking on Bedrock,
# speaking on subscription), edit ``mind/config/model.yml`` instead.
# That file declares the backend explicitly and the worker reads it at
# startup; the env vars below remain the credential source.
#
# Detection (when model.yml is absent): presence of ANTHROPIC_BASE_URL
# or ANTHROPIC_API_KEY selects api-mode; otherwise CLAUDE_CODE_OAUTH_TOKEN
# selects subscription-mode. Don't set both — the worker explicitly
# clears the unused side, but leaving stale values around is confusing.

# Mode 1: subscription (Claude account).
# Mint a long-lived OAuth token with:
#     claude setup-token
# It opens a browser; the CLI prints a token starting with 'sk-ant-oat01-…'.
# Paste that value here. Do NOT use 'claude /login' — on macOS that token
# lives in the system Keychain (the container can't reach it), and even on
# Linux refreshes don't propagate cleanly through the bind mount. Billing
# uses your Claude subscription.
CLAUDE_CODE_OAUTH_TOKEN=

# Mode 2: API key (direct Anthropic, or via LiteLLM / any proxy).
# Use a raw Anthropic API key, optionally routed through an
# Anthropic-compatible proxy (e.g. LiteLLM). Leave ANTHROPIC_BASE_URL
# blank to talk to api.anthropic.com directly. Set it to your proxy URL
# (e.g. http://litellm.example:4000) to route through there. The model
# name we send (see alice.config.json `speaking.model`) must match a
# route configured at the proxy.
# ANTHROPIC_AUTH_TOKEN is optional bearer-token-style proxy auth — only
# set it if your proxy expects an Authorization: Bearer header in
# addition to (or instead of) x-api-key.
ANTHROPIC_BASE_URL=
ANTHROPIC_API_KEY=
ANTHROPIC_AUTH_TOKEN=

# --- Signal (optional) -----------------------------------------------------
# SIGNAL_API is set by docker-compose (the worker reaches the daemon at
# http://alice-daemon:8080 on the internal Docker network). Only set it here
# if you're running the bridge outside the normal compose layout.
#
# Leave SIGNAL_ACCOUNT empty to disable Signal entirely — the daemon's
# signal-cli service idles, and only the CLI / Discord transports run.
# To enable: set the E.164 number Alice sends from and register the
# account once via:
#   docker exec -it alice-daemon signal-cli -a +15555550100 link -n "Alice"
SIGNAL_ACCOUNT=

# Comma-separated allowlist of senders who can message Alice.
# Format: "+15555550100:DisplayName,+15555550101:Other"
# Ignored when SIGNAL_ACCOUNT is empty.
ALLOWED_SENDERS=

# Claude Code working directory inside the container.
# Should always be /home/alice/alice-mind in the default setup.
WORK_DIR=/home/alice/alice-mind

# Max seconds a single claude invocation is allowed to run.
# Must be strictly less than FLOCK_TIMEOUT so the lock always releases before
# the next queued message times out.
CLAUDE_TIMEOUT=240

# Max seconds a queued message will wait for the per-sender lock.
FLOCK_TIMEOUT=300

# Tools exposed to claude inside signal-bridge invocations.
# Drop Bash from this list to reduce prompt-injection blast radius.
CLAUDE_ALLOWED_TOOLS=Bash,Read,Write,Edit,Glob,Grep

# --- Discord (optional) ----------------------------------------------------
# Alice can also talk over Discord (DMs and mentions in guilds she's been
# invited to). Leave DISCORD_BOT_TOKEN empty to disable; the daemon skips
# Discord construction entirely and existing Signal-only deploys are
# unaffected.
#
# To enable:
#   1. Create a bot at https://discord.com/developers/applications, copy
#      its token into DISCORD_BOT_TOKEN below.
#   2. Enable the "Message Content" privileged intent on the bot's app page.
#   3. Invite the bot to your guild with the `bot` scope and at minimum
#      Send Messages + Read Message History permissions.
#   4. Add a Discord channel entry to each principal you want speaking on
#      Discord (in alice-mind/config/principals.yaml) — DMs match by user
#      id, guild messages match by channel id.
DISCORD_BOT_TOKEN=

# --- GitHub (optional) -----------------------------------------------------
# Personal access token for the gh CLI (and git-over-https, which routes
# through gh's credential helper). Set this if you want Alice to use a
# dedicated PAT — easier to scope narrowly and rotate independently of
# your host login. Leave blank to fall through to whatever
# ~/.config/gh/hosts.yml has via the read-only mount.
#
# Mint at https://github.com/settings/tokens (or `gh auth token` after
# scope-adjusting an existing login). Recommended scopes for typical
# Alice use: repo, gist, workflow, read:org. Add notifications /
# admin:repo_hook only if Alice needs them.
GH_TOKEN=

# --- A2A (optional) --------------------------------------------------------
# Inbound A2A (Google Agent2Agent) protocol server — lets external A2A-
# compliant agents submit text tasks to Alice and stream replies back. When
# disabled (the default) Alice still talks via Signal/Discord/CLI; A2A just
# isn't reachable.
#
# Port is bound INSIDE the worker container only. To expose to the host,
# add a docker-compose.override.yml that publishes ALICE_A2A_PORT to the
# slot you care about (or front the workers with a reverse proxy that
# targets the lease-holder).
#
# v1: all A2A traffic shares one principal (ALICE_A2A_PRINCIPAL); per-caller
# auth lives in whatever proxy you put in front (oauth2-proxy / Caddy /
# Cloudflare Access / etc.). Per-caller principal lookup is a follow-up.
ALICE_A2A_ENABLED=
ALICE_A2A_PORT=7878
ALICE_A2A_HOST=0.0.0.0
ALICE_A2A_PRINCIPAL=a2a
# Public URL advertised on the agent card at /.well-known/agent-card.json.
# Leave blank to default to http://<ALICE_A2A_HOST>:<ALICE_A2A_PORT>/. Set
# this to the externally-reachable URL when fronted by a reverse proxy
# (e.g. https://alice.example.com/a2a).
ALICE_A2A_EXTERNAL_URL=
